{
  "mappings": [
    {
      "priority": "1",
      "request": {
        "method": "POST",
        "url": "/payments",
        "bodyPatterns": [
          { "matchesJsonPath": "$[?(@.amount > 1000)]" }
        ]
      },
      "response": {
        "status": 402,
        "body": "Limit exceeded"
      }
    },
    {
      "priority": "2",
      "request": {
        "method": "POST",
        "url": "/payments",
        "bodyPatterns": [
          { "matchesJsonPath": "$[?(@.amount <= 1000)]" }
        ]
      },
      "response": {
        "status": 202,
        "body": "Accepted"
      }
    }
  ]
}