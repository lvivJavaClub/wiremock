{
  "mappings": [
    {
      "scenarioName": "AuthFlow",
      "requiredScenarioState": "Started",
      "request": {
        "method": "POST",
        "url": "/login"
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "jsonBody": { "token": "token-abc-123" }
      },
      "newScenarioState": "LoggedIn"
    },
    {
      "scenarioName": "AuthFlow",
      "requiredScenarioState": "LoggedIn",
      "request": {
        "method": "GET",
        "url": "/profile",
        "headers": {
          "Authorization": { "equalTo": "Bearer token-abc-123" }
        }
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "jsonBody": { "id": 42, "name": "Alice", "role": "USER" }
      }
    }
  ]
}